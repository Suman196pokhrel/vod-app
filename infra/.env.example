# =============================================================================
# VOD PROJECT - LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to your docker/local.env (or wherever your compose file lives)
# DO NOT commit this file to version control
# =============================================================================


# -----------------------------------------------------------------------------
# POSTGRES
# -----------------------------------------------------------------------------
POSTGRES_USER=vod_user
POSTGRES_PASSWORD=vod_password
POSTGRES_DB=vod_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full DSN for the API / worker
DATABASE_URL=postgresql+asyncpg://vod_user:vod_password@postgres:5432/vod_db
# Sync version (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://vod_user:vod_password@postgres:5432/vod_db


# -----------------------------------------------------------------------------
# PGADMIN
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_dev_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:redis_dev_password@redis:6379/0


# -----------------------------------------------------------------------------
# CELERY  (Flower reads CELERY_BROKER_URL directly)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:redis_dev_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_dev_password@redis:6379/1


# -----------------------------------------------------------------------------
# MINIO  (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_HOST=minio
MINIO_PORT=9000

# These match what pydantic Settings expects (snake_case)
minio_endpoint=minio:9000
minio_access_key=minioadmin
minio_secret_key=minioadmin123
minio_bucket_videos=vod-videos
minio_bucket_processed_videos=vod-processed
minio_bucket_thumbnails=vod-thumbnails


# -----------------------------------------------------------------------------
# API / FASTAPI
# -----------------------------------------------------------------------------
APP_ENV=local
DEBUG=true
SECRET_KEY=super-secret-local-key-change-me-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost,http://localhost:3000

# JWT — matches pydantic field name jwt_secret_key
jwt_secret_key=local-jwt-secret-change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL (used for email links, CORS, etc.)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# EMAIL  (Resend)
# -----------------------------------------------------------------------------
# from_email must match a verified sender domain in your Resend account
# For local dev you can use a dummy value if email sending is not needed
RESEND_API_KEY=dummy_key
from_email=noreply@your_custom_domain.com

# -----------------------------------------------------------------------------
# FFMPEG
# -----------------------------------------------------------------------------
# Must be a plain integer — no parentheses, no quotes
FFMPEG_THREADS=2